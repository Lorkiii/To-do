// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String         @id @default(uuid())
  email             String         @unique
  name              String?
  username          String         @unique
  passwordHash      String
  birthDate         DateTime?
  usernameChangedAt DateTime?
  createdAt         DateTime       @default(now())
  posts             Post[]
  tasks             Task[]
  taskTemplates     TaskTemplate[]
  mediaAssets       MediaAsset[]
  settings          UserSettings?
}

model UserSettings {
  id                   String   @id @default(uuid())
  userId               String   @unique
  notificationsEnabled Boolean  @default(true)
  theme                 String   @default("dark")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id           String      @id @default(uuid())
  title        String
  content      String?
  published    Boolean     @default(false)
  coverImageId String?
  coverImage   MediaAsset? @relation("PostCoverImage", fields: [coverImageId], references: [id])
  postImages   PostImage[]
  author       User?       @relation(fields: [authorId], references: [id])
  authorId     String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?
}

model MediaAsset {
  id           String      @id @default(uuid())
  ownerId      String
  owner        User        @relation(fields: [ownerId], references: [id])
  url          String
  pathName     String
  fileName     String
  fileType     String
  contentType  String
  sizeBytes    Int
  width        Int
  height       Int
  cropX        Int?
  cropY        Int?
  cropWidth    Int?
  cropHeight   Int?
  alt          String?
  coverForPost Post[]       @relation("PostCoverImage")
  postImages   PostImage[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  @@index([ownerId])
}

model PostImage {
  id           String     @id @default(uuid())
  postId       String
  mediaAssetId String
  position     Int        @default(0)
  caption      String?
  altText      String?
  mediaAsset   MediaAsset @relation(fields: [mediaAssetId], references: [id])
  post         Post       @relation(fields: [postId], references: [id])

  @@index([postId, position])
  @@index([mediaAssetId])
}

model Task {
  id             String              @id @default(uuid())
  title          String
  description    String
  priority       String
  status         String
  authorId       String?
  author         User?               @relation(fields: [authorId], references: [id])
  checklistItems TaskChecklistItem[]
  dueDate        DateTime?
  pinned         Boolean             @default(false)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?
}

model TaskTemplate {
  // Reusable task starter saved by one user.
  id             String                      @id @default(uuid())
  name           String
  title          String
  description    String
  priority       String
  status         String
  authorId       String
  author         User                        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  checklistItems TaskTemplateChecklistItem[]
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
}

model TaskChecklistItem {
  id        String   @id @default(uuid())
  title     String
  completed Boolean  @default(false)
  position  Int      @default(0)
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId, position])
}

model TaskTemplateChecklistItem {
  // Ordered checklist step belonging to a saved template.
  id         String       @id @default(uuid())
  title      String
  position   Int          @default(0)
  templateId String
  template   TaskTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([templateId, position])
}
